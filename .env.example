# OpenChart Pro 环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 交易所选择: okx | binance
CRYPTO_EXCHANGE=okx

# OKX API（实盘交易需要）
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# AI/LLM（AI研判需要）
# 选择: deepseek | qwen
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# 新闻数据（可选）
FINNHUB_API_KEY=

# 链上数据（可选）
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
